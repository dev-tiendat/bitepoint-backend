    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "fastify": "4.28.1",
    "https-proxy-agent": "^7.0.5",
    "ioredis": "^5.4.1",
    "lodash": "^4.17.21",
    "mysql2": "^3.11.3",
    "nanoid": "3",
    "nestjs-cls": "^4.4.1",
    "nestjs-form-data": "^1.9.91",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
